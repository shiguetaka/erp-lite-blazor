@page "/"
@using ERP.Web.Services
@inject ClienteApiService ClienteService
@inject ProdutoApiService ProdutoService
@inject VendaApiService VendaService

<h1>Dashboard</h1>

<div class="dashboard">

    <div class="card">
        <h3>Clientes</h3>
        <p>@totalClientes</p>
    </div>
    
    <div class="card">
        <h3>Produtos</h3>
        <p>@totalProdutos</p>
    </div>

    <div class="card">
        <h3>Vendas</h3>
        <p>@totalVendas</p>
    </div>
    
</div>

@code {

    private int totalClientes;
    private int totalProdutos;
    private int totalVendas;

    protected override async Task OnInitializedAsync()
    {
        totalClientes = await ClienteService.CountAsync();
        totalProdutos = await ProdutoService.CountAsync();
        totalVendas = await VendaService.CountAsync();
    }
}